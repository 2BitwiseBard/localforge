# LocalForge Environment Variables
# =================================
# Copy to .env and fill in your values.
# Generate API keys: python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# Gateway API key (required)
LOCALFORGE_API_KEY=change-me-generate-a-real-key

# Backend URL (default: http://localhost:5000/v1)
# LOCALFORGE_BACKEND_URL=http://localhost:5000/v1

# Config file path (default: auto-detected relative to server.py)
# LOCALFORGE_CONFIG=/path/to/config.yaml

# Data directory for notes, indexes, sessions, etc.
# (default: ~/.local/share/localforge)
# LOCALFORGE_DATA_DIR=~/.local/share/localforge

# Gateway bind settings
# LOCALFORGE_GATEWAY_HOST=0.0.0.0
# LOCALFORGE_GATEWAY_PORT=8100

# text-generation-webui root (for presets, grammars)
# LOCALFORGE_WEBUI_ROOT=~/text-generation-webui

# text-generation-webui API key (if --api-key is set)
# LOCALFORGE_BACKEND_API_KEY=

# Telegram bot token (optional, from @BotFather)
# LOCALFORGE_TELEGRAM_TOKEN=
